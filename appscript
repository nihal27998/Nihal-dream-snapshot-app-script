// ============================================================
// ✅ MAIN FUNCTION
// ============================================================
function generateForActiveRow() {
  const sheet      = SpreadsheetApp.getActiveSheet();
  const row        = sheet.getActiveCell().getRow();
  const transcript = sheet.getRange(row, 8).getValue();  // Column H
  const statusCell = sheet.getRange(row, 9);             // Column I
  const outputCell = sheet.getRange(row, 10);            // Column J

  if (row === 1) {
    outputCell.setValue("⚠️ Please select a data row, not the header.");
    return;
  }

  if (!transcript || transcript.toString().trim() === "") {
    outputCell.setValue("❌ No transcript found in Column H for Row " + row);
    statusCell.setValue("⚠️ Skipped");
    return;
  }

  outputCell.setValue("⏳ Processing Row " + row + "...");
  statusCell.setValue("⏳ Processing...");
  SpreadsheetApp.flush();

  try {
    const trimmed = transcript.toString().trim().substring(0, 6000);

    // STEP 1: Extract only business owner's statements
    const ownerOnly = extractOwnerStatements(trimmed);

    // STEP 2: Classify into 12 dimensions
    const classificationJSON = classifyTranscript(ownerOnly);

    // STEP 3: Generate full Dream Snapshot
    const snapshot = generateSnapshot(classificationJSON, ownerOnly);

    outputCell.setValue(snapshot || "⚠️ Empty response from Gemini");
    statusCell.setValue("✅ Done");

  } catch (err) {
    outputCell.setValue("❌ ERROR:\n" + err.message);
    statusCell.setValue("⚠️ Failed");
    Logger.log("Error: " + err.message);
  }
}

