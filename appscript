// ✅ STAGE 0: EXTRACT OWNER STATEMENTS
// ============================================================
function extractOwnerStatements(transcript) {
  const prompt = `
You are reading a sales or discovery call transcript between a BD person and a Business Owner.

Your task:
- Figure out who the Business Owner is. They talk about their business, their team, their challenges. They are NOT the one pitching or selling.
- Copy out ONLY what the Business Owner said, word for word, in the order they said it.
- Remove everything the BD person said.
- Do NOT summarise or rephrase. Just give the owner's exact words as a numbered list.
- If you cannot clearly tell who the owner is, include everything that is NOT a sales pitch.

Transcript:
${transcript}
`;
  return callGemini(prompt);
}

